  "item": [
    {
      "name": "POST Crear Tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201 Created\", () => {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "pm.test(\"Respuesta contiene id numerico\", () => {\r",
              "    const b = pm.response.json();\r",
              "    pm.expect(b).to.have.property(\"id\");\r",
              "    pm.environment.set(\"tareaId\", b.id);\r",
              "});\r",
              "pm.test(\"Tiempo de respuesta menor a 500ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"titulo\": \"Tarea de prueba Newman\",\r\n    \"descripcion\": \"Creada por colección Postman\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
