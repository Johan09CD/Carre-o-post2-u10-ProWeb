{
  "info": {
    "_postman_id": "a32cefd0-f21e-4dd7-abce-46424603ac1f",
    "name": "API ToDoApp",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST Crear Tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201 Created\", () => {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Respuesta contiene id numerico\", () => {",
              "    const b = pm.response.json();",
              "    pm.expect(b).to.have.property(\"id\");",
              "    pm.environment.set(\"tareaId\", b.id);",
              "});",
              "pm.test(\"Tiempo de respuesta menor a 500ms\", () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"titulo\": \"Tarea de prueba Newman\",\n    \"descripcion\": \"Creada por colección Postman\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/tareas",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas"]
        }
      }
    },
    {
      "name": "GET Obtener Tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK\", () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Titulo correcto\", () => {",
              "    const b = pm.response.json();",
              "    pm.expect(b.titulo).to.eql(\"Tarea de prueba Newman\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tareas/{{tareaId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas", "{{tareaId}}"]
        }
      }
    },
    {
      "name": "PATCH Completar Tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK\", () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Tarea marcada como completada\", () => {",
              "    const b = pm.response.json();",
              "    pm.expect(b.completada).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tareas/{{tareaId}}/completar",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas", "{{tareaId}}", "completar"]
        }
      }
    },
    {
      "name": "GET Verificar Completada",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK\", () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Completada es true\", () => {",
              "    const b = pm.response.json();",
              "    pm.expect(b.completada).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tareas/{{tareaId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas", "{{tareaId}}"]
        }
      }
    },
    {
      "name": "GET Tarea Inexistente 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 404 Not Found\", () => {",
              "    pm.response.to.have.status(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tareas/99999",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas", "99999"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "tareaId",
      "value": ""
    }
  ]
}